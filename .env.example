# Public environment variables (available in browser) must be prefixed with VITE_
# VITE_PUBLIC_API_URL=https://api.example.com

# Cloudflare deployment secrets (used by GitHub Actions / Wrangler)
# Do NOT commit real values — set them as repository secrets or in your shell.
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_API_TOKEN=your-api-token
