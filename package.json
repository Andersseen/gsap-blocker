{
  "name": "gsap-blocker",
  "version": "0.1.0",
  "description": "Reusable GSAP-powered directives, components and pre-built animation blocks for Angular.",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "BUILD_PRESET=cloudflare-pages vite build",
    "preview": "pnpm build && wrangler pages dev ./dist/analog/public",
    "deploy": "pnpm run build && pnpm run deploy:pages",
    "deploy:pages": "wrangler pages deploy ./dist/analog/public --project-name=gsap-blocker",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "wrangler:types": "wrangler types"
  },
  "private": true,
  "dependencies": {
    "@analogjs/router": "^1.15.1",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "gsap": "^3.13.0",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.12",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^1.15.1",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@eslint/js": "^9.22.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/node": "^20.17.19",
    "angular-eslint": "^20.7.0",
    "eslint": "9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "front-matter": "^4.0.2",
    "husky": "^9.1.0",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.4.0",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.0.0"
  }
}
